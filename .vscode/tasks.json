{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "check-stale-extension",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/check-stale-extension.sh",
      "presentation": { "reveal": "silent", "close": true }
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "dependsOn": ["check-stale-extension"]
    },
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": "build",
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
