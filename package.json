{
  "name": "conductor",
  "displayName": "Conductor",
  "description": "Real-time dashboard visualizing Claude Code AI agent activity, tool usage, and token consumption",
  "version": "0.1.0",
  "publisher": "conductor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/conductor"
  },
  "homepage": "https://github.com/anthropics/conductor#readme",
  "bugs": {
    "url": "https://github.com/anthropics/conductor/issues"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/taitopia"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "conductor.open",
        "title": "Conductor: Open"
      },
      {
        "command": "conductor.refresh",
        "title": "Conductor: Refresh"
      },
      {
        "command": "conductor.launchSession",
        "title": "Conductor: Launch Claude Session"
      }
    ],
    "configuration": {
      "title": "Conductor",
      "properties": {
        "conductor.additionalWorkspaces": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "window",
          "markdownDescription": "Additional workspace paths to monitor for Claude Code sessions. Use absolute paths (e.g., `/Users/you/other-project`)."
        },
        "conductor.launchCommand": {
          "type": "string",
          "default": "claude",
          "scope": "window",
          "markdownDescription": "Shell command used to launch Claude Code sessions from Conductor. Change this if `claude` is not in your PATH or you use a custom wrapper."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production && npm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "node esbuild.js --watch",
    "dev:webview": "cd webview-ui && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:all": "npm run lint && npm run lint:eslint",
    "prepare": "[ -d .git ] && git config core.hooksPath .githooks || true",
    "docs": "typedoc",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.18.0",
    "eslint-plugin-jsdoc": "~50.6.0",
    "prettier": "^3.2.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.2.0"
  }
}
