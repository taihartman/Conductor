{
  "name": "claude-agent-dashboard",
  "displayName": "Claude Agent Dashboard",
  "description": "Real-time dashboard visualizing Claude Code AI agent activity, tool usage, and token consumption",
  "version": "0.1.0",
  "publisher": "claude-dashboard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claude-agent-dashboard"
  },
  "homepage": "https://github.com/anthropics/claude-agent-dashboard#readme",
  "bugs": {
    "url": "https://github.com/anthropics/claude-agent-dashboard/issues"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeAgentDashboard.open",
        "title": "Claude Agent Dashboard: Open"
      },
      {
        "command": "claudeAgentDashboard.refresh",
        "title": "Claude Agent Dashboard: Refresh"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production && npm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "node esbuild.js --watch",
    "dev:webview": "cd webview-ui && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "docs": "typedoc",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "prettier": "^3.2.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "vitest": "^1.2.0"
  }
}
